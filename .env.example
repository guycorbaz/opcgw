# =============================================================================
# opcgw — environment configuration
#
# This is the SINGLE place that holds the gateway's environment configuration.
# docker-compose.yml loads it via `env_file: .env`, so every variable defined
# here is passed to the container; nothing is set in the compose file itself.
#
# Setup:
#   cp .env.example .env
#   # edit .env and set the REQUIRED values below
#   chmod 600 .env
#   docker compose up
#
# `.env` is git-ignored; this `.env.example` ships placeholders only and is
# safe to commit.
#
# Every variable uses the OPCGW_ prefix; `__` (double underscore) separates
# nested configuration keys. The variables below are the ones most deployments
# need. ANY configuration key can be overridden the same way — see the
# "Environment Variable Reference" appendix in the user manual for the full
# list and the value each one expects.
# =============================================================================

# --- SECRETS (optional — the first-run web wizard can collect these) ---------
#
# Story F-2: the ChirpStack API token and the OPC UA password can be supplied
# through the browser at http://<host>:<port>/setup on first boot (it writes
# them to config/secrets.toml, file mode 0600). Set them here ONLY if you want
# to skip the wizard / provision unattended. Leave them commented out to use
# the zero-touch wizard. NOTE: the web-UI login user/password and the log-file
# location DO belong in this file (see below) — the wizard never touches those.

# ChirpStack API token. Must have permission to list applications/devices,
# read metrics, and access the configured tenant.
#OPCGW_CHIRPSTACK__API_TOKEN=replace-with-your-chirpstack-api-token

# OPC UA / Web UI password. Paired with the user name below; also used for the
# web UI's HTTP Basic auth. Choose a strong value.
#OPCGW_OPCUA__USER_PASSWORD=replace-with-a-strong-password

# --- COMMON (uncomment to override the built-in defaults) --------------------

# ChirpStack gRPC endpoint (host:port).
#OPCGW_CHIRPSTACK__SERVER_ADDRESS=chirpstack.example.com:8080

# OPC UA / Web UI user name. Default: opcua-user
#OPCGW_OPCUA__USER_NAME=opcua-user

# OPC UA listen port. Default: 4840 (standard OPC UA port). If you change it,
# update the published port in docker-compose.yml to match.
#OPCGW_OPCUA__HOST_PORT=4840

# Enable the embedded web UI (first-run wizard + configuration). Default: true
#OPCGW_WEB__ENABLED=true

# Web UI port. Default: 8080. docker-compose.yml publishes this port.
#OPCGW_WEB__PORT=8080

# Log verbosity: error | warn | info | debug | trace. Default: info
#OPCGW_LOG_LEVEL=info
