# =============================================================================
# opcgw — secret-credential template for Compose / `.env`-based deployments
#
# Copy this file to `.env` and replace each placeholder with the real secret
# value, then start the gateway via `docker compose up`. Compose auto-loads
# `.env` from this directory and substitutes the values into the container's
# environment per `docker-compose.yml`.
#
# `.env` is excluded from git via `.gitignore` ("# Config & Secrets" block);
# this `.env.example` ships placeholders only so the file is safe to commit.
#
# After populating real values:
#   chmod 600 .env
#   docker compose up
#
# See docs/security.md for the full env-var recipe (Kubernetes, anti-patterns,
# the redacted `Debug` contract, etc.).
# =============================================================================

# ChirpStack API token — must have permissions to list applications/devices,
# read metrics, and access the configured tenant.
OPCGW_CHIRPSTACK__API_TOKEN=REPLACE_ME_WITH_OPCGW_CHIRPSTACK__API_TOKEN_ENV_VAR

# OPC UA user password — paired with the `[opcua].user_name` field in
# `config/config.toml`. Used when OPC UA clients authenticate.
OPCGW_OPCUA__USER_PASSWORD=REPLACE_ME_WITH_OPCGW_OPCUA__USER_PASSWORD_ENV_VAR
